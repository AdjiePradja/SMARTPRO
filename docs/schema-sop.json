{
  "doc_type": "SOP",
  "doc_type_label": "STANDARD OPERATING PROCEDURE",
  "version": "1.0",
  "note": "Schema acuan dokumen pertama. Jadi sumber tunggal untuk form, preview, dan PDF. Struktur ini SAMA untuk semua 7 departemen; yang berbeda hanya isi yang diketik user.",

  "header_fields": {
    "note": "Bagian kop dokumen. Sebagian auto-generate, sebagian read-only mengikuti sistem.",
    "fields": [
      { "key": "no_dokumen", "label": "No. Dokumen", "type": "auto", "manual_toggle": true, "pattern": "PPA-ADRO-SOP-{DEPT}-{NN}" },
      { "key": "no_revisi", "label": "No. Revisi", "type": "auto", "default": 0 },
      { "key": "edisi", "label": "Edisi", "type": "auto", "default": 1 },
      { "key": "tgl_terbit", "label": "Tgl. Terbit", "type": "auto_date", "fill_on": "published" },
      { "key": "tgl_revisi", "label": "Tgl. Revisi", "type": "auto_date", "fill_on": "revision" },
      { "key": "judul_dokumen", "label": "Judul Dokumen", "type": "text", "required": true },
      { "key": "departemen", "label": "Departemen", "type": "auto", "source": "user.department" },
      { "key": "pembuat", "label": "Pembuat", "type": "auto", "source": "user.name" }
    ]
  },

  "shared_partials": {
    "header": "_kop",
    "footer": "_footer",
    "footer_text": "Dokumen elektronik ini merupakan dokumen tidak terkendali apabila dicetak.",
    "approval_page": "_pengesahan"
  },

  "steps": [
    {
      "step": 1,
      "title": "Tujuan & Ruang Lingkup",
      "sections": [
        {
          "key": "tujuan",
          "label": "I. TUJUAN",
          "type": "rich_list",
          "auto_number": "1.",
          "min_items": 1,
          "placeholder": "Masukkan poin tujuan..."
        },
        {
          "key": "ruang_lingkup",
          "label": "II. RUANG LINGKUP",
          "type": "rich_list",
          "auto_number": "2.",
          "min_items": 1,
          "placeholder": "Masukkan poin ruang lingkup..."
        }
      ]
    },
    {
      "step": 2,
      "title": "Referensi & Definisi",
      "sections": [
        {
          "key": "referensi",
          "label": "III. REFERENSI",
          "type": "reference_picker",
          "allow_add": true,
          "placeholder": "Masukkan referensi..."
        },
        {
          "key": "definisi",
          "label": "IV. DEFINISI",
          "type": "rich_list",
          "auto_number": "4.",
          "placeholder": "Masukkan definisi..."
        }
      ]
    },
    {
      "step": 3,
      "title": "Aktivitas & Tanggung Jawab",
      "sections": [
        {
          "key": "aktivitas",
          "label": "V. AKTIVITAS DAN TANGGUNG JAWAB",
          "type": "repeatable_group",
          "add_button_label": "+ Tambah Aktivitas/Tanggung Jawab",
          "min_groups": 1,
          "group_fields": [
            { "key": "sub_judul", "label": "Sub Judul", "type": "text", "placeholder": "Sub Judul (Contoh: Tahap Persiapan)" },
            { "key": "deskripsi", "label": "Deskripsi Aktivitas", "type": "textarea", "placeholder": "Deskripsi aktivitas..." },
            { "key": "pic", "label": "PIC", "type": "text", "placeholder": "PIC (Contoh: Tim ICT)" }
          ]
        }
      ]
    },
    {
      "step": 4,
      "title": "Lampiran",
      "sections": [
        {
          "key": "lampiran",
          "label": "VI. LAMPIRAN",
          "type": "repeatable_group",
          "add_button_label": "+ Tambah Lampiran Baru",
          "min_groups": 0,
          "group_fields": [
            { "key": "judul", "label": "Judul Lampiran", "type": "text", "placeholder": "Judul Lampiran (Contoh: Form Ceklis)" },
            {
              "key": "isi",
              "label": "Isi Lampiran (pilih salah satu: teks atau gambar)",
              "type": "text_or_image",
              "text_placeholder": "Masukkan keterangan teks jika ada...",
              "image_accept": "image/jpeg,image/png",
              "image_max_mb": 2
            }
          ]
        }
      ]
    },
    {
      "step": 5,
      "title": "Verifikasi & Approval",
      "sections": [
        {
          "key": "pembuat_tambahan",
          "label": "Pembuat Tambahan (opsional)",
          "type": "user_picker",
          "multiple": true,
          "required": false,
          "hint": "Gunakan tombol + jika pembuat lebih dari 1 orang."
        },
        {
          "key": "peninjau",
          "label": "Ditinjau Oleh (DH/SH)",
          "type": "user_picker",
          "role_filter": ["group_leader", "section_head"],
          "required": true
        },
        {
          "key": "penyetuju",
          "label": "Disetujui Oleh (PJO)",
          "type": "user_picker",
          "role_filter": ["pimpinan"],
          "required": true
        }
      ]
    }
  ],

  "approval_page_layout": {
    "note": "Tabel halaman pengesahan pada PDF cetak.",
    "columns": ["Nama", "Jabatan", "Tanggal", "Pengesahan"],
    "rows": [
      { "role_label": "Dibuat Oleh", "role": "pembuat" },
      { "role_label": "Ditinjau Oleh", "role": "peninjau" },
      { "role_label": "Disetujui Oleh", "role": "penyetuju" }
    ],
    "stamp_on_published": "APPROVED"
  }
}
