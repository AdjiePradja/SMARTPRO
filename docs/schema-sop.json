{
  "doc_type": "SOP",
  "doc_type_label": "STANDARD OPERATING PROCEDURE",
  "schema_version": "3.0",
  "note": "Cetak biru dokumen SOP. Sumber tunggal untuk form, preview, dan PDF. Struktur SAMA untuk 7 departemen; yang berbeda hanya isi yang diketik user. Pengisian 2 STEP.",

  "header_fields": {
    "note": "Kop dokumen. Sebagian auto, sebagian read-only mengikuti sistem.",
    "fields": [
      { "key": "no_dokumen", "label": "No. Dokumen", "type": "auto", "manual_toggle": true, "pattern": "PPA-ADRO-SOP-{DEPT}-{NN}", "temporary_until": "approved", "temp_label": "Nomor sementara - final setelah disetujui" },
      { "key": "no_revisi", "label": "No. Revisi", "type": "auto", "default": 0 },
      { "key": "edisi", "label": "Edisi", "type": "auto", "default": 1 },
      { "key": "tgl_terbit", "label": "Tgl. Terbit", "type": "auto_date", "fill_on": "published" },
      { "key": "tgl_revisi", "label": "Tgl. Revisi", "type": "auto_date", "fill_on": "revision" },
      { "key": "judul_dokumen", "label": "Judul Dokumen", "type": "text", "required": true },
      { "key": "departemen", "label": "Departemen", "type": "auto", "source": "user.department" },
      { "key": "pembuat", "label": "Pembuat", "type": "auto", "source": "user.name" }
    ]
  },

  "shared_partials": {
    "header": "_kop",
    "footer": "_footer",
    "footer_text": "Dokumen elektronik ini merupakan dokumen tidak terkendali apabila dicetak.",
    "approval_page": "_pengesahan",
    "logo_path": "public/images/logo-ppa.png"
  },

  "steps": [
    {
      "step": 1,
      "title": "Isi Utama",
      "sections": [
        { "key": "tujuan", "label": "I. TUJUAN", "type": "rich_list", "auto_number": "1.", "min_items": 1, "placeholder": "Masukkan poin tujuan..." },
        { "key": "ruang_lingkup", "label": "II. RUANG LINGKUP", "type": "rich_list", "auto_number": "2.", "min_items": 1, "placeholder": "Masukkan poin ruang lingkup..." },
        { "key": "referensi", "label": "III. REFERENSI", "type": "reference_picker", "allow_add": true, "placeholder": "Masukkan referensi..." },
        { "key": "definisi", "label": "IV. DEFINISI", "type": "rich_list", "auto_number": "4.", "placeholder": "Masukkan definisi..." }
      ]
    },
    {
      "step": 2,
      "title": "Aktivitas, Lampiran & Verifikasi",
      "sections": [
        {
          "key": "aktivitas",
          "label": "V. AKTIVITAS DAN TANGGUNG JAWAB",
          "type": "repeatable_group",
          "add_button_label": "+ Tambah Aktivitas/Tanggung Jawab",
          "min_groups": 1,
          "group_fields": [
            { "key": "sub_judul", "label": "Sub Judul", "type": "text", "placeholder": "Sub Judul (Contoh: Tahap Persiapan)" },
            { "key": "deskripsi", "label": "Deskripsi Aktivitas", "type": "textarea", "placeholder": "Deskripsi aktivitas..." },
            { "key": "pic", "label": "PIC", "type": "text", "placeholder": "PIC (Contoh: Tim ICT)" }
          ]
        },
        {
          "key": "lampiran",
          "label": "VI. LAMPIRAN",
          "type": "repeatable_group",
          "add_button_label": "+ Tambah Lampiran Baru",
          "min_groups": 0,
          "group_fields": [
            { "key": "judul", "label": "Judul Lampiran", "type": "text", "placeholder": "Judul Lampiran (Contoh: Form Ceklis)" },
            { "key": "isi", "label": "Isi Lampiran (pilih salah satu: teks atau gambar)", "type": "text_or_image", "text_placeholder": "Masukkan keterangan teks jika ada...", "image_accept": "image/jpeg,image/png", "image_max_mb": 2, "storage_path": "storage/app/public/lampiran/{DEPT}/SOP/" }
          ]
        },
        {
          "key": "verifikasi",
          "label": "Verifikasi & Approval",
          "type": "verification_block",
          "note": "Peninjau & approver dipilih pembuat. Dropdown menampilkan Nama + NRP + Dept. Pilihan dibatasi sesuai jabatan pembuat (lihat PRD Bagian 3.2).",
          "fields": [
            { "key": "pembuat_tambahan", "label": "Pembuat Tambahan (opsional)", "type": "user_picker", "multiple": true, "required": false, "hint": "Hanya pembuat utama yang tanda tangan; tambahan tercatat di log." },
            { "key": "peninjau", "label": "Ditinjau Oleh", "type": "user_picker", "required": true, "role_filter_dynamic": "by_creator_jabatan" },
            { "key": "penyetuju", "label": "Disetujui Oleh", "type": "user_picker", "required": true, "role_filter_dynamic": "by_creator_jabatan" }
          ]
        }
      ]
    }
  ],

  "approval_page_layout": {
    "note": "Tabel halaman pengesahan pada PDF. Hanya pembuat utama di 'Dibuat Oleh'.",
    "columns": ["Nama", "Jabatan", "Tanggal", "Pengesahan"],
    "rows": [
      { "role_label": "Dibuat Oleh", "role": "pembuat_utama" },
      { "role_label": "Ditinjau Oleh", "role": "peninjau" },
      { "role_label": "Disetujui Oleh", "role": "penyetuju" }
    ],
    "stamp_on_published": "APPROVED"
  }
}
